{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/types": ["./types"],
      "@/types/*": ["./types/*"],
      "@/hooks": ["./hooks"],
      "@/hooks/*": ["./hooks/*"],
      "@/components": ["./components"],
      "@/components/*": ["./components/*"],
      "@/constants": ["./constants"],
      "@/constants/*": ["./constants/*"],
      "@/services": ["./services"],
      "@/services/*": ["./services/*"],
      "@/utils": ["./utils"],
      "@/utils/*": ["./utils/*"],
      "@cosmo/types": ["../../packages/types/src"],
      "@cosmo/constants": ["../../packages/constants/src"]
    }
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
