# Whisper AI - Environment Variables Template
# Copy this to .env and fill in your values

# ===== Turso / libSQL (Auth, Profiles, Billing) =====
# Use TURSO_DATABASE_URL for a hosted Turso database.
# If unset, the app falls back to the local file at WHISPER_DB_PATH.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
WHISPER_DB_PATH=data/db/whisper.db

# ===== AI Services (Optional) =====
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your_google_ai_api_key
HF_TOKEN=your_huggingface_token
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_IDS=

# ===== Hugging Face Dataset Sync (Optional) =====
HF_DATASET_REPO=your-user/whisper-trained-data
HF_SPACE_ID=https://shubhjn-whisper-ai.hf.space

# ===== Cloudflare Crawl (Optional, preferred research crawler) =====
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_CRAWL_ENABLED=true
CLOUDFLARE_CRAWL_PLAN=free
CLOUDFLARE_REST_REQUESTS_PER_MINUTE=6
CLOUDFLARE_CRAWL_JOBS_PER_DAY=5
CLOUDFLARE_CRAWL_PAGES_PER_JOB=100
CLOUDFLARE_CRAWL_POLL_INTERVAL_SECONDS=10
CLOUDFLARE_CRAWL_MAX_POLLS=60
RESEARCH_REQUIRE_ALLOWED_SOURCES=false
RESEARCH_REQUIRE_LICENSE_METADATA=false
RESEARCH_ALLOWED_DOMAINS=
RESEARCH_ALLOWED_PREFIXES=
RESEARCH_BLOCKED_DOMAINS=

# ===== Admin =====
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_HASH=
ALLOW_LEGACY_ADMIN=false
JWT_SECRET=your-secret-key-minimum-32-characters

# ===== Encryption =====
ENCRYPTION_KEY=
ENCRYPTION_SALT=whisper-ai-salt-2024

# ===== Server Config =====
PORT=8000
HOST=0.0.0.0

# ===== Local Runtime =====
LOCAL_CHAT_BACKEND=auto
LOCAL_MODEL_ID=Qwen/Qwen2.5-Coder-0.5B-Instruct
LOCAL_GGUF_MODEL_PATH=
AIRLLM_MODEL_ID=
LOCAL_AIRLLM_MODEL_PATH=
LOCAL_MAX_CONTEXT_TOKENS=4096
LOCAL_MAX_NEW_TOKENS=512

# ===== Data Collection / Vision Feed =====
IMAGE_ENCODER_BACKEND=local
IMAGE_ENCODER_URL=https://shubhjn-image-encoder.hf.space
AUTO_COLLECTION_ENABLED=true
AUTO_COLLECTION_INTERVAL_SECONDS=3600
WHISPER_MAX_VISION_STORE=1000

# ===== Auth Test / Local Verification =====
GOOGLE_TEST_ID_TOKEN_SECRET=

WHISPER_DATA_ROOT=data
WHISPER_MODELS_DIR=models
WHISPER_UPLOADS_DIR=uploads
