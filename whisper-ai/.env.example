# Whisper AI - Environment Variables Template
# Copy this to .env and fill in your values

# ===== Turso / libSQL (Auth, Profiles, Billing) =====
# Use TURSO_DATABASE_URL for a hosted Turso database.
# If unset, the app falls back to the local file at WHISPER_DB_PATH.
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
WHISPER_DB_PATH=data/db/whisper.db

# ===== AI Services (Optional) =====
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your_google_ai_api_key
HF_TOKEN=your_huggingface_token
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_IDS=

# ===== Hugging Face Dataset Sync (Optional) =====
HF_DATASET_REPO=shubhjn/whisper-data
HF_SPACE_ID=https://shubhjn-whisper-ai.hf.space

# ===== Cloudflare Crawl (Optional, preferred research crawler) =====
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_CRAWL_ENABLED=true
CLOUDFLARE_CRAWL_PLAN=free
CLOUDFLARE_REST_REQUESTS_PER_MINUTE=6
CLOUDFLARE_CRAWL_JOBS_PER_DAY=5
CLOUDFLARE_CRAWL_PAGES_PER_JOB=100
CLOUDFLARE_CRAWL_POLL_INTERVAL_SECONDS=10
CLOUDFLARE_CRAWL_MAX_POLLS=60
RESEARCH_REQUIRE_ALLOWED_SOURCES=false
RESEARCH_REQUIRE_LICENSE_METADATA=false
RESEARCH_ALLOWED_DOMAINS=
RESEARCH_ALLOWED_PREFIXES=
RESEARCH_BLOCKED_DOMAINS=

# ===== Admin =====
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_HASH=
ALLOW_LEGACY_ADMIN=false
JWT_SECRET=your-secret-key-minimum-32-characters

# ===== Encryption =====
ENCRYPTION_KEY=
ENCRYPTION_SALT=whisper-ai-salt-2024

# ===== Server Config =====
PORT=8000
HOST=0.0.0.0

# ===== Local Runtime =====
LOCAL_CHAT_BACKEND=auto
LOCAL_MODEL_ID=Qwen/Qwen3-1.7B
LOCAL_GGUF_MODEL_PATH=
AIRLLM_MODEL_ID=
LOCAL_AIRLLM_MODEL_PATH=
LOCAL_MAX_CONTEXT_TOKENS=4096
LOCAL_MAX_NEW_TOKENS=512
WHISPER_COMPLEX_TASK_ROUTING=true
WHISPER_COMPLEX_TASK_MODEL_ID=Qwen/Qwen3-Coder-Next
WHISPER_COMPLEX_TASK_MAX_CONTEXT_TOKENS=16384
WHISPER_COMPLEX_TASK_MAX_NEW_TOKENS=1024
WHISPER_COMPLEX_TASK_TRUST_REMOTE_CODE=true
WHISPER_COMPLEX_TASK_THRESHOLD=0.55
WHISPER_CURATED_TEXT_MAX_ROWS=25000
WHISPER_CURATED_IMAGE_PROMPT_MAX_ROWS=50000
WHISPER_IMAGE_PROMPT_PRIOR_ENABLED=true
WHISPER_IMAGE_PROMPT_PRIOR_MAX_PROMPTS=2000
WHISPER_DYNAMIC_RANDOM_WIKIPEDIA_PAGES=4
WHISPER_DYNAMIC_RESEARCH_DOCS=10
WHISPER_DYNAMIC_GUTENBERG_DISCOVERIES=4
WHISPER_DYNAMIC_ARXIV_DISCOVERIES=4
WHISPER_DYNAMIC_WEB_FETCH_LIMIT=12
WHISPER_SELF_LEARNER_TEXT_FALLBACK=true
WHISPER_SELF_LEARNER_IMAGE_FALLBACK_LOCAL=true

# ===== Local Multimodal Adapter Overrides (Optional) =====
# If unset, the server auto-detects:
# - MiMo on http://127.0.0.1:8001
# - GLM-OCR on http://127.0.0.1:8002
# - PersonaPlex on http://127.0.0.1:8003
# - BitNet model/repo from the managed models directory
LOCAL_MIMO_BASE_URL=
LOCAL_MIMO_MODEL_ID=XiaomiMiMo/MiMo-V2-Flash
LOCAL_MIMO_API_KEY=
LOCAL_MIMO_COMMAND_TEMPLATE=
LOCAL_MIMO_COMMAND_CWD=
LOCAL_GLM_OCR_BASE_URL=
LOCAL_GLM_OCR_MODEL_ID=zai-org/GLM-OCR
LOCAL_GLM_OCR_API_KEY=
LOCAL_GLM_OCR_COMMAND_TEMPLATE=
LOCAL_GLM_OCR_COMMAND_CWD=
PERSONAPLEX_ENDPOINT_URL=
PERSONAPLEX_MODEL_ID=nvidia/personaplex-7b-v1
PERSONAPLEX_AUTH_TOKEN=
LOCAL_BITNET_MODEL_PATH=
LOCAL_BITNET_REPO_PATH=
LOCAL_BITNET_ENTRYPOINT=
LOCAL_BITNET_COMMAND_TEMPLATE=
LOCAL_BITNET_COMMAND_CWD=

# ===== Data Collection / Vision Feed =====
IMAGE_ENCODER_BACKEND=local
IMAGE_ENCODER_URL=https://shubhjn-image-encoder.hf.space
AUTO_COLLECTION_ENABLED=true
AUTO_COLLECTION_INTERVAL_SECONDS=3600
WHISPER_MAX_VISION_STORE=1000

# ===== Auth Test / Local Verification =====
GOOGLE_TEST_ID_TOKEN_SECRET=

# ===== Storage Paths =====
# Local development defaults
WHISPER_DATA_ROOT=data
WHISPER_MODELS_DIR=data/models
WHISPER_UPLOADS_DIR=data/uploads

# Hugging Face Space persistent-volume overrides
# WHISPER_DATA_ROOT=/data/whisper
# WHISPER_MODELS_DIR=/data/whisper/models
# WHISPER_UPLOADS_DIR=/data/whisper/uploads
# WHISPER_PERSISTENT_VOLUME_ROOT=/data/whisper
# WHISPER_USE_PERSISTENT_VOLUME=true
# PYTHONUSERBASE=/data/whisper/runtime/python-user-base
# HF_HOME=/data/whisper/runtime/huggingface
# HUGGINGFACE_HUB_CACHE=/data/whisper/runtime/huggingface/hub

