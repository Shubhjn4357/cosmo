# Whisper App - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SERVER API
# ===========================================
# The mobile app talks only to the Whisper server API.
# Auth, profiles, chat history, billing, and preferences are stored server-side
# in Turso/libSQL. No client-side database keys are required here.
EXPO_PUBLIC_API_BASE_URL=https://shubhjn-whisper-ai.hf.space

# ===========================================
# GOOGLE OAUTH
# ===========================================
# Get these from: https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# ===========================================
# BUY ME A COFFEE
# ===========================================
EXPO_PUBLIC_BMC_USERNAME=ShubhJn

# ===========================================
# RAZORPAY (for in-app payments)
# ===========================================
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
