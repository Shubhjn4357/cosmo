{
  "expo": {
    "name": "Whisper AI",
    "slug": "whisper",
    "version": "3.4.5b",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "whisper",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whisper.ai",
      "deploymentTarget": "17.0",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "MODEL_DOWNLOAD_TASK",
          "MODEL_CLEANUP_TASK"
        ]
      },
      "associatedDomains": [
        "applinks:whisper-ai.app"
      ]
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.whisper.ai",
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "whisper-ai.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "whisper",
              "host": "*"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withCustomProguard",
      [
        
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true,
            "deploymentTarget": "17.0"
          },
          "android": {
            "newArchEnabled": true,
            "minSdkVersion": 33,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1808892410-1av3kgpjirumb2q3uk8b3su71tnifge3"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
        }
      ],
      [
        "expo-file-system",
        {
          "ios": {
            "newArchEnabled": true,
            "deploymentTarget": "17.0"
          },
          "android": {
            "newArchEnabled": true,
            "minSdkVersion": 33,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "pixelatedvibe",
    "extra": {
      "router": {},
      "googleWebClientId": "1808892410-pbju1r4qjb6stu6u0u5tgldt4mq37cs6.apps.googleusercontent.com",
      "googleAndroidClientId": "1808892410-i8rfbh0da0kmk7853dqn9ltevi3andkl.apps.googleusercontent.com",
      "googleIosClientId": "1808892410-1av3kgpjirumb2q3uk8b3su71tnifge3.apps.googleusercontent.com",
      "eas": {
        "projectId": "6a40787a-01e8-4114-8e02-94e52320e0f2"
      }
    }
  }
}
